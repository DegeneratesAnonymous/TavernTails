# TavernTAIls Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets!

# ===================================
# DATABASE CONFIGURATION
# ===================================
# SQLite (dev) or PostgreSQL (prod) connection string
# Dev default: sqlite:///./taverntails.db
# Prod example: postgresql://user:password@host:5432/taverntails
TAVERNTAILS_DATABASE_URL=sqlite:///./taverntails.db

# ===================================
# AUTHENTICATION & SECURITY
# ===================================
# JWT signing secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(48))")
# CRITICAL: Change this in production and rotate monthly
TAVERNTAILS_SECRET=your-secret-key-here-replace-in-production

# Auto-seed dev user (test@example.com / secret) for local development
# Set to 0 in production
TAVERNTAILS_SEED_DEV_USER=1

# ===================================
# STORAGE CONFIGURATION
# ===================================
# Storage mode: 'local' (filesystem) or 's3' (S3-compatible object store)
TAVERNTAILS_STORAGE_MODE=local

# AWS S3 Configuration (only needed if TAVERNTAILS_STORAGE_MODE=s3)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1
# TAVERNTAILS_S3_BUCKET=taverntails-sessions

# ===================================
# AI AGENT CONFIGURATION
# ===================================
# Enable AI-powered agents (false = use deterministic stubs)
# Set to false for development to avoid API costs
TAVERNTAILS_ENABLE_AI_AGENTS=false

# LLM Provider: openai, anthropic, local, azure
TAVERNTAILS_LLM_PROVIDER=openai

# OpenAI Configuration
# Get API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_MAX_TOKENS=1000
# OPENAI_TEMPERATURE=0.7

# Anthropic Configuration
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-sonnet

# Local Model Configuration (Ollama, LM Studio)
# LOCAL_LLM_URL=http://localhost:11434/api/generate
# LOCAL_LLM_MODEL=llama2

# Azure OpenAI Configuration
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=...
# AZURE_OPENAI_DEPLOYMENT=gpt-35-turbo

# ===================================
# IMAGE GENERATION CONFIGURATION
# ===================================
# Image provider: stability, dalle, midjourney, local
TAVERNTAILS_IMAGE_PROVIDER=stability

# Stability AI Configuration
# Get API key from: https://platform.stability.ai/
# STABILITY_API_KEY=sk-...
# STABILITY_MODEL=stable-diffusion-xl
# STABILITY_STYLE=fantasy

# DALL-E Configuration (uses OPENAI_API_KEY)
# DALLE_MODEL=dall-e-3
# DALLE_SIZE=1024x1024
# DALLE_QUALITY=standard

# Local Stable Diffusion
# LOCAL_SD_URL=http://localhost:7860/api/txt2img
# LOCAL_SD_MODEL=sd_xl_base_1.0

# ===================================
# SAFETY AND MODERATION
# ===================================
# Enable content moderation for AI-generated content
# CRITICAL: Should be true in production
TAVERNTAILS_ENABLE_CONTENT_MODERATION=true

# Enable image safety checks
TAVERNTAILS_ENABLE_IMAGE_MODERATION=true

# Agent operation timeout in seconds
TAVERNTAILS_AGENT_TIMEOUT_SECONDS=30

# Max retry attempts for failed agent calls
TAVERNTAILS_AGENT_MAX_RETRIES=2

# ===================================
# AUDIT LOGGING (CRITICAL FOR SECURITY)
# ===================================
# Enable audit logging for all agent actions
# Logs to agent_events table for PM review
# CRITICAL: Should be true in production
TAVERNTAILS_ENABLE_AUDIT_LOGGING=true

# Audit log retention in days
TAVERNTAILS_AUDIT_LOG_RETENTION_DAYS=90

# ===================================
# RATE LIMITING (PLACEHOLDER - TO BE IMPLEMENTED)
# ===================================
# Enable rate limiting middleware
# TODO: Wire up rate limiting middleware in server/main.py
TAVERNTAILS_RATE_LIMIT_ENABLED=false

# Global rate limit: requests per hour per user
TAVERNTAILS_RATE_LIMIT_REQUESTS_PER_HOUR=100

# Per-endpoint rate limits (JSON format)
# Example: {"narrative": 30, "image": 10, "chat": 100}
TAVERNTAILS_RATE_LIMIT_PER_ENDPOINT={"narrative": 30, "image": 10, "chat": 100}

# Rate limit storage: memory, redis
# Use redis in production for multi-instance deployments
TAVERNTAILS_RATE_LIMIT_STORAGE=memory

# Redis Configuration (for rate limiting and caching in production)
# TAVERNTAILS_REDIS_URL=redis://localhost:6379/0

# ===================================
# RESPONSE CACHING
# ===================================
# Enable caching of AI responses to reduce costs
TAVERNTAILS_ENABLE_RESPONSE_CACHING=false

# Cache TTL in seconds (default: 1 hour)
TAVERNTAILS_CACHE_TTL_SECONDS=3600

# Max cache size in MB
TAVERNTAILS_CACHE_MAX_SIZE_MB=500

# ===================================
# COST MANAGEMENT
# ===================================
# Maximum monthly spend on AI APIs (USD)
# Alert PM if exceeded
TAVERNTAILS_MAX_MONTHLY_SPEND_USD=100

# Maximum tokens per user per month
TAVERNTAILS_MAX_TOKENS_PER_USER=10000

# ===================================
# EMAIL CONFIGURATION
# ===================================
# SMTP settings for email verification and invites
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=your-email@example.com
# EMAIL_SMTP_PASSWORD=your-app-password
# EMAIL_FROM_ADDRESS=noreply@taverntails.com

# ===================================
# APPLICATION SETTINGS
# ===================================
# Environment: local, staging, production
TAVERNTAILS_ENVIRONMENT=local

# Frontend URL (for CORS and email links)
TAVERNTAILS_FRONTEND_URL=http://localhost:3000

# Backend URL
TAVERNTAILS_BACKEND_URL=http://localhost:8000

# Enable debug logging
TAVERNTAILS_DEBUG=true

# ===================================
# EXTERNAL INTEGRATIONS
# ===================================
# DnD Beyond OAuth (for character import)
# DNDBEYOND_CLIENT_ID=...
# DNDBEYOND_CLIENT_SECRET=...
# DNDBEYOND_REDIRECT_URI=http://localhost:3000/auth/dndbeyond/callback

# Beyond20 integration (for dice rolls)
# No configuration needed - endpoint at /integrations/beyond20/roll

# ===================================
# MONITORING AND TELEMETRY (FUTURE)
# ===================================
# OpenTelemetry configuration (when implemented)
# TAVERNTAILS_ENABLE_TELEMETRY=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=taverntails-backend

# Prometheus metrics endpoint (when implemented)
# TAVERNTAILS_ENABLE_METRICS=false

# ===================================
# NOTES
# ===================================
# - Keep .env file out of version control (already in .gitignore)
# - Rotate TAVERNTAILS_SECRET monthly (see docs/SECRET_MANAGEMENT.md)
# - Use different secrets for dev, staging, and production
# - Store production secrets in a secret manager (AWS Secrets Manager, Azure Key Vault, etc.)
# - Review docs/AGENT_GUARDRAILS.md for security best practices
# - See docs/LLM_IMAGE_CONFIG.md for AI provider setup details
