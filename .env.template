# OpenAI API key used for embeddings & assistant features
OPENAI_API_KEY=

# OpenAI model used for narrative and content generation.
# Recommended: gpt-4o (best quality), gpt-4o-mini (cost-efficient / dev), gpt-4.1, o4-mini
OPENAI_MODEL=gpt-4o

