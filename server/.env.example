# TavernTAIls Backend Environment Configuration
# Copy this file to .env and fill in your values

# Database Configuration
# For local development, SQLite is the default (no setup required)
# For production, use PostgreSQL
DATABASE_URL=sqlite:///./taverntails.db
# Production example:
# DATABASE_URL=postgresql://user:password@localhost:5432/taverntails

# Security & Authentication
# Generate a secure random secret key for JWT signing
# Example: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production
# Algorithm for JWT signing (HS256 = HMAC-SHA256, secure and recommended)
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
# Comma-separated list of allowed origins
# For local dev:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# For production, add your domain:
# CORS_ORIGINS=https://taverntails.com,https://www.taverntails.com

# ── Steward AI Integration (recommended when running alongside the Steward dashboard) ──
# When STEWARD_HOST is set, TavernTails routes all AI generation through Steward's
# LLM stack instead of calling Ollama or OpenAI directly.  Steward handles model
# selection, node routing (heatherpc / colemanpc), and fallback automatically.
# The Steward dashboard injects this automatically when launching from the Games tab.
# STEWARD_HOST=http://127.0.0.1:5555
#
# Controls which Steward routing tier is used:
#   short_summary  – fast, always-available (heatherpc / qwen3:8b)  [default]
#   creative_story – higher quality (colemanpc / gemma3:27b) when available
# STEWARD_TASK_SCOPE=short_summary

# ── Ollama (direct, fallback if STEWARD_HOST not set) ─────────────────────────
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen3:4b

# ── LLM Configuration (OpenAI, last resort) ───────────────────────────────────
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
# Model to use for narrative and content generation.
# Recommended values:
#   gpt-4o          – best quality, default for production
#   gpt-4o-mini     – cost-efficient, suitable for development / testing
#   gpt-4.1         – high capability, newer generation
#   o4-mini         – reasoning-optimised, higher latency
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7
# Optional: Organization ID
# OPENAI_ORG_ID=org-your-org-id

# Image Generation (Stability AI)
# Get your API key from https://platform.stability.ai/
STABILITY_API_KEY=your-stability-api-key-here
STABILITY_MODEL=sd3-turbo
STABILITY_IMAGE_SIZE=1024x1024
STABILITY_STEPS=20

# Alternative LLM Provider (Anthropic Claude) - Optional
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# Session Storage
# Local filesystem (default for development)
SESSIONS_STORAGE_TYPE=local
SESSIONS_BASE_PATH=./server/sessions
# Production: S3-compatible storage
# SESSIONS_STORAGE_TYPE=s3
# S3_BUCKET_NAME=taverntails-sessions
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_ENDPOINT_URL=https://s3.amazonaws.com  # Or custom S3-compatible endpoint

# Optional: Redis for WebSocket scaling and caching
# Required for horizontal scaling beyond single server
# REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0

# Email Configuration (for verification emails)
# SMTP settings for sending emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@taverntails.com
# SMTP_TLS=true

# Application Settings
# Environment: development, staging, production
ENVIRONMENT=development
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Enable debug mode (disable in production!)
DEBUG=true

# Rate Limiting
# Limits per minute/hour to prevent abuse
LLM_RATE_LIMIT_PER_MINUTE=30
LLM_MAX_CALLS_PER_SESSION=150
IMAGE_RATE_LIMIT_PER_HOUR=10
IMAGE_MAX_PER_SESSION=15

# Usage Tracking & Monitoring
# Enable to track API usage and costs
ENABLE_USAGE_TRACKING=true
USAGE_LOG_PATH=./logs/usage.json
# Budget alerts (optional)
# MONTHLY_LLM_BUDGET_USD=100
# MONTHLY_IMAGE_BUDGET_USD=50
# ALERT_EMAIL=admin@taverntails.com

# Feature Flags
# Toggle features on/off
ENABLE_WEBSOCKETS=true
ENABLE_BEYOND20_INTEGRATION=true
ENABLE_PDF_IMPORT=false
ENABLE_DND_BEYOND_SYNC=false

# Server Configuration
HOST=127.0.0.1
PORT=8000
RELOAD=true  # Auto-reload on code changes (dev only)

# Testing Configuration
# Override values for test environment
# TEST_DATABASE_URL=sqlite:///./test_taverntails.db
