# TavernTAIls Frontend Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
# Backend API base URL
REACT_APP_API_URL=http://localhost:8000
# For production, use your deployed backend URL:
# REACT_APP_API_URL=https://api.taverntails.com

# WebSocket Configuration
# WebSocket endpoint for real-time updates
REACT_APP_WS_URL=ws://localhost:8000/ws
# For production (use wss:// for secure WebSocket):
# REACT_APP_WS_URL=wss://api.taverntails.com/ws

# Application Settings
# Application name displayed in UI
REACT_APP_NAME=TavernTAIls
# Environment: development, staging, production
REACT_APP_ENV=development

# Feature Flags
# Enable/disable features in the UI
REACT_APP_ENABLE_IMAGE_GENERATION=true
REACT_APP_ENABLE_BEYOND20=true
REACT_APP_ENABLE_PDF_IMPORT=false
REACT_APP_ENABLE_DND_BEYOND_SYNC=false

# Analytics (Optional)
# Google Analytics tracking ID
# REACT_APP_GA_TRACKING_ID=G-XXXXXXXXXX
# Sentry DSN for error tracking
# REACT_APP_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Advanced Settings
# Maximum WebSocket reconnection attempts
REACT_APP_WS_MAX_RECONNECT_ATTEMPTS=5
# API request timeout (milliseconds)
REACT_APP_API_TIMEOUT=30000
# Enable debug logging in browser console
REACT_APP_DEBUG=true

# Note: All REACT_APP_* variables are embedded in the build
# Do NOT put sensitive secrets here - they will be visible in the browser!
