# Python cache / bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/

# Node modules (built in Docker, not needed from host)
client/node_modules/
node_modules/

# Frontend production build (rebuilt inside Docker)
client/build/

# Test and coverage artefacts
.coverage
.pytest_cache/
htmlcov/

# Runtime / local databases
*.db
*.sqlite
server/sessions/

# Logs
*.log
logs/

# OS noise
.DS_Store
Thumbs.db

# Editor / IDE configs
.vscode/
.idea/

# Environment files — never bake secrets into the image
.env
.env.local
.env.production
.env.staging

# Git metadata (not needed inside image)
.git/
.github/
